APP_NAME=EduAppMai
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

POSTGRES_DB=eduapp
POSTGRES_USER=eduapp_user
POSTGRES_PASSWORD=eduapp_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

DATABASE_URL=postgresql+psycopg://eduapp_user:eduapp_password@db:5432/eduapp
REDIS_URL=redis://redis:6379/0

JWT_SECRET_KEY=change_me_for_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
AUTH_COOKIE_NAME=access_token
REDIS_QUEUE_NAME=submission_queue
RUNNER_IMAGE=eduapp_runner:latest
RUNNER_CPU_LIMIT=0.5
RUNNER_MEMORY_LIMIT_MB=256
RUNNER_TIMEOUT_SEC=2
PROJECT_ROOT=/app
